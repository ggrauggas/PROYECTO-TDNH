# ─────────────────────────────────────────────────────────────
# .env.example (raíz) — usado por docker-compose en desarrollo
# Copia este archivo a .env y ajusta los valores.
# Para desplegar en producción, mira backend/.env.example y
# frontend/.env.example.
# ─────────────────────────────────────────────────────────────

# Base de datos (docker-compose)
DB_NAME=tudiabetes
DB_USER=tudiabetes_user
DB_PASSWORD=tudiabetes_password
DB_ROOT_PASSWORD=rootpassword

# Backend
NODE_ENV=development
PORT=3000
JWT_SECRET=cambia_esto_por_un_secreto_aleatorio_largo
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Email (verificación de cuenta)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contrasena_de_aplicacion
EMAIL_FROM=tu_correo@gmail.com

# Frontend (dev)
VUE_APP_API_URL=http://localhost:3000/api
