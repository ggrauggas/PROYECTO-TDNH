# ─────────────────────────────────────────────────────────────
# frontend/.env.example
# Variables del frontend Vue CLI (deben empezar por VUE_APP_).
#
# Desarrollo local → copia a frontend/.env.development.local
# Producción (Netlify) → define estas variables en el dashboard
#   de Netlify (Site settings → Environment variables), no en .env
# ─────────────────────────────────────────────────────────────

# URL completa de la API del backend (con /api al final)
# Desarrollo:
# VUE_APP_API_URL=http://localhost:3000/api
# Producción (Render):
VUE_APP_API_URL=https://tu-backend.onrender.com/api

VUE_APP_TITLE=TU diabetes NUESTRA historia
