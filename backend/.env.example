# ─────────────────────────────────────────────────────────────
# backend/.env.example
# Variables del backend Express.
#
# Local (sin Docker): copia a backend/.env y usa DB_* con Postgres local.
# Producción (Render): configura estas variables en el dashboard de Render.
# ─────────────────────────────────────────────────────────────

# Entorno
NODE_ENV=production
PORT=3000

# ── Base de datos ──
# Opción A — Producción (Neon, Supabase, Render Postgres…):
# Usa la cadena de conexión completa. Forzará SSL automáticamente.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Opción B — Desarrollo local con variables separadas
# (déjalas vacías si usas DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tudiabetes
DB_USER=tudiabetes_user
DB_PASSWORD=tudiabetes_password

# ── Autenticación ──
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=genera_un_secreto_aleatorio_de_al_menos_48_bytes
JWT_EXPIRES_IN=7d

# ── CORS ──
# Lista separada por comas de orígenes permitidos (sin slash final)
# En producción debe ser exactamente el dominio del frontend de Netlify
CORS_ORIGIN=https://tu-sitio.netlify.app
